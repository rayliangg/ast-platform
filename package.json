{
  "name": "ast-platform",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.4.1"
  },
  "scripts": {
    "ui:install": "npm --prefix apps/ui install",
    "ui:dev": "npm --prefix apps/ui run dev",
    "ui:build": "npm --prefix apps/ui run build",
    "parse:server": "node scripts/parse-server.mjs",
    "gift:diff": "node scripts/gift.mjs",
    "desktop": "npm run ui:build && electron .",
    "desktop:dev": "cross-env ELECTRON_DEV=1 electron ."
  }
}
